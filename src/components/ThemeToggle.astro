---
import { Icon } from "astro-icon/components";
---

<button
	aria-label="切换到深色模式"
	class="relative btn-plain scale-animation h-11 w-11 rounded-lg transition-transform duration-150 ease-out active:scale-[0.96]"
	data-theme-toggle
	title="切换到深色模式"
	type="button"
>
	<div class="absolute dark:opacity-0">
		<Icon name="material-symbols:wb-sunny-outline-rounded" class="text-[1.25rem]" />
	</div>
	<div class="absolute opacity-0 dark:opacity-100">
		<Icon name="material-symbols:dark-mode-outline-rounded" class="text-[1.25rem]" />
	</div>
</button>

<script>
	import { DARK_MODE, LIGHT_MODE } from "@constants/constants";
	import { getStoredTheme, setTheme } from "@utils/setting-utils";

	function syncThemeToggles() {
		const mode = getStoredTheme();
		const nextLabel = mode === DARK_MODE ? "切换到浅色模式" : "切换到深色模式";

		document.querySelectorAll("[data-theme-toggle]").forEach((node) => {
			if (!(node instanceof HTMLButtonElement)) return;
			node.setAttribute("aria-label", nextLabel);
			node.setAttribute("title", nextLabel);
		});
	}

	function toggleTheme() {
		const nextMode = getStoredTheme() === DARK_MODE ? LIGHT_MODE : DARK_MODE;
		setTheme(nextMode);
		syncThemeToggles();
	}

	if (!(window).__pwnShrineThemeToggleBound) {
		(window).__pwnShrineThemeToggleBound = true;

		document.addEventListener("click", (event) => {
			const target = event.target;
			if (!(target instanceof Element)) return;
			const toggle = target.closest("[data-theme-toggle]");
			if (!(toggle instanceof HTMLButtonElement)) return;
			toggleTheme();
		});

		const observer = new MutationObserver(() => {
			syncThemeToggles();
		});

		observer.observe(document.body, {
			childList: true,
			subtree: true,
		});
	}

	syncThemeToggles();
</script>
