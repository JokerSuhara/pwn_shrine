---
interface Props {
	title: string;
}

const { title } = Astro.props;
const skeletonRows = Array.from({ length: 6 });
const sideRows = Array.from({ length: 5 });
---

<section class="mx-auto flex max-w-6xl flex-col gap-4">
	<div class="card-base overflow-hidden shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_1px_2px_-1px_rgba(0,0,0,0.06),0_2px_4px_rgba(0,0,0,0.04)] transition-[box-shadow,background-color] duration-150 ease-out dark:shadow-[0_0_0_1px_rgba(255,255,255,0.08)]">
		<div class="border-b border-black/10 px-5 py-4 dark:border-white/10 md:px-6">
			<div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
				<div class="min-w-0">
					<div class="text-xs font-semibold uppercase tracking-[0.12em] text-30">Pwn.Shrine</div>
					<h1 class="mt-1 text-balance text-2xl font-bold text-90 md:text-3xl">{title}</h1>
				</div>
				<div class="flex h-10 w-full max-w-xs items-center rounded-lg bg-black/[0.035] px-3 shadow-[inset_0_0_0_1px_rgba(0,0,0,0.06)] dark:bg-white/[0.045] dark:shadow-[inset_0_0_0_1px_rgba(255,255,255,0.08)]" aria-hidden="true">
					<div class="h-2.5 w-24 rounded-full bg-black/10 dark:bg-white/10"></div>
				</div>
			</div>
		</div>

		<div class="flex items-center gap-1 overflow-x-auto border-b border-black/10 px-3 py-2 dark:border-white/10 md:px-4" aria-hidden="true">
			<div class="h-8 w-20 shrink-0 rounded-md bg-[var(--btn-plain-bg-hover)] shadow-[inset_0_0_0_1px_rgba(0,0,0,0.04)] dark:shadow-[inset_0_0_0_1px_rgba(255,255,255,0.06)]"></div>
			<div class="h-8 w-24 shrink-0 rounded-md bg-black/[0.035] dark:bg-white/[0.045]"></div>
			<div class="h-8 w-16 shrink-0 rounded-md bg-black/[0.035] dark:bg-white/[0.045]"></div>
			<div class="h-8 w-28 shrink-0 rounded-md bg-black/[0.035] dark:bg-white/[0.045]"></div>
		</div>

		<div class="grid gap-0 lg:grid-cols-[15rem_minmax(0,1fr)]">
			<aside class="border-b border-black/10 bg-black/[0.015] p-4 dark:border-white/10 dark:bg-white/[0.02] lg:border-b-0 lg:border-r" aria-hidden="true">
				<div class="mb-4 h-8 rounded-md bg-black/[0.045] dark:bg-white/[0.055]"></div>
				<div class="flex flex-col gap-2">
					{sideRows.map((_, index) => (
						<div class="flex items-center gap-2 rounded-md px-2 py-1.5">
							<div class:list={[
								"h-2.5 w-2.5 rounded-full",
								index === 0 ? "bg-[var(--primary)]/45" : "bg-black/10 dark:bg-white/10",
							]}></div>
							<div class:list={[
								"h-2.5 rounded-full bg-black/10 dark:bg-white/10",
								index % 2 === 0 ? "w-24" : "w-32",
							]}></div>
						</div>
					))}
				</div>
			</aside>

			<div class="min-w-0 p-4 md:p-5">
				<div class="mb-4 grid gap-3 md:grid-cols-3" aria-hidden="true">
					<div class="rounded-lg bg-black/[0.025] p-4 shadow-[inset_0_0_0_1px_rgba(0,0,0,0.05)] dark:bg-white/[0.03] dark:shadow-[inset_0_0_0_1px_rgba(255,255,255,0.07)]">
						<div class="h-2.5 w-16 rounded-full bg-black/10 dark:bg-white/10"></div>
						<div class="mt-3 h-5 w-10 rounded-full bg-black/10 dark:bg-white/10"></div>
					</div>
					<div class="rounded-lg bg-black/[0.025] p-4 shadow-[inset_0_0_0_1px_rgba(0,0,0,0.05)] dark:bg-white/[0.03] dark:shadow-[inset_0_0_0_1px_rgba(255,255,255,0.07)]">
						<div class="h-2.5 w-20 rounded-full bg-black/10 dark:bg-white/10"></div>
						<div class="mt-3 h-5 w-12 rounded-full bg-black/10 dark:bg-white/10"></div>
					</div>
					<div class="rounded-lg bg-black/[0.025] p-4 shadow-[inset_0_0_0_1px_rgba(0,0,0,0.05)] dark:bg-white/[0.03] dark:shadow-[inset_0_0_0_1px_rgba(255,255,255,0.07)]">
						<div class="h-2.5 w-14 rounded-full bg-black/10 dark:bg-white/10"></div>
						<div class="mt-3 h-5 w-16 rounded-full bg-black/10 dark:bg-white/10"></div>
					</div>
				</div>

				<div class="overflow-hidden rounded-lg shadow-[0_0_0_1px_rgba(0,0,0,0.06)] dark:shadow-[0_0_0_1px_rgba(255,255,255,0.08)]" aria-hidden="true">
					<div class="flex items-center justify-between bg-black/[0.025] px-4 py-3 dark:bg-white/[0.03]">
						<div class="h-3 w-32 rounded-full bg-black/10 dark:bg-white/10"></div>
						<div class="h-8 w-20 rounded-md bg-[var(--btn-regular-bg)]"></div>
					</div>
					<div class="divide-y divide-black/10 dark:divide-white/10">
						{skeletonRows.map((_, index) => (
							<div class="grid grid-cols-[minmax(0,1fr)_5rem] gap-4 px-4 py-3">
								<div class="min-w-0">
									<div class:list={[
										"h-3 rounded-full bg-black/10 dark:bg-white/10",
										index % 3 === 0 ? "w-3/5" : index % 3 === 1 ? "w-4/5" : "w-2/5",
									]}></div>
									<div class="mt-2 h-2.5 w-1/3 rounded-full bg-black/[0.07] dark:bg-white/[0.08]"></div>
								</div>
								<div class="h-6 rounded-full bg-black/[0.06] dark:bg-white/[0.07]"></div>
							</div>
						))}
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
